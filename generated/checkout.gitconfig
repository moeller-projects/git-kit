[alias]
    co = checkout
    swb = switch --create
    swi = "!f() { command -v fzf >/dev/null 2>&1 || { echo \"swi needs fzf (use: git switch <branch>)\" >&2; return 2; }; b=\"$(git for-each-ref --format=\"%(refname:short)\" refs/heads/ refs/remotes/origin/ | grep -v \"^origin/HEAD$\" | fzf --preview \"git log --oneline --color=always -20 {}\" --prompt=\"switch> \")\"; [ -n \"$b\" ] || return 0; git switch \"$(echo \"$b\" | sed \"s#^origin/##\")\"; }; f"
    swr = "!f() { command -v fzf >/dev/null 2>&1 || { echo \"swr needs fzf\" >&2; return 2; }; b=\"$(git for-each-ref --sort=-committerdate --count=20 --format=\"%(refname:short)\" refs/heads/ | fzf --preview \"git log --oneline --color=always -20 {}\" --prompt=\"recent> \")\"; [ -n \"$b\" ] || return 0; git switch \"$b\"; }; f"
    sw- = switch -
