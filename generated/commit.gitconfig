[alias]
    ca = commit --amend
    cam = commit --amend --message
    cane = commit --amend --no-edit
    cm = commit --message
    wip = !git add --all && git commit --message=wip
    unwip = "!f() { msg=\"$(git log -1 --pretty=%s)\"; test \"$msg\" = \"wip\" || { echo \"last commit message is not 'wip' (found: '${msg}')\"; return 1; }; git reset HEAD~1; }; f"
    save = "!f() { msg=\"${1:-wip}\"; git add --all && git commit --message \"$msg\"; }; f"
    savep = "!f() { msg=\"${1:-wip}\"; git add --patch && git commit --message \"$msg\"; }; f"
