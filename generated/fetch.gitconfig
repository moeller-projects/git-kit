[alias]
    fa = fetch --all
    fap = fetch --all --prune
    pr-fetch = "!f() { [ -n \"$1\" ] || { echo \"usage: git pr-fetch <number> [remote]\" >&2; return 2; }; remote=\"${2:-origin}\"; branch=\"pr-$1\"; if [ \"$(git current-branch)\" = \"$branch\" ]; then git fetch \"$remote\" \"pull/$1/head\" && git merge --ff-only FETCH_HEAD; else git fetch \"$remote\" \"pull/$1/head:$branch\" && git switch \"$branch\"; fi; }; f"
