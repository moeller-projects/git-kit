[alias]
    flow-task-start = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-task-start <name> [base]\"; return 2; }; base=\"${2:-$(git default-branch)}\"; path=\"$(git wt-path \"task/$name\")\" || return; git worktree add -b \"task/$name\" \"$path\" \"$base\"; }; f"
    flow-task-done = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-task-done <name>\"; return 2; }; path=\"$(git wt-path \"task/$name\")\" || return; git worktree remove \"$path\" && git branch --delete \"task/$name\"; }; f"
    flow-feature-start = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-feature-start <name> [base]\"; return 2; }; base=\"${2:-$(git default-branch)}\"; path=\"$(git wt-path \"feature/$name\")\" || return; git worktree add -b \"feature/$name\" \"$path\" \"$base\"; }; f"
    flow-feature-finish = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-feature-finish <name>\"; return 2; }; base=\"$(git default-branch)\"; path=\"$(git wt-path \"feature/$name\")\" || return; git checkout \"$base\" && git merge --no-ff \"feature/$name\" && git worktree remove \"$path\" && git branch --delete \"feature/$name\"; }; f"
    flow-hotfix-start = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-hotfix-start <name> [base]\"; return 2; }; base=\"${2:-$(git default-branch)}\"; path=\"$(git wt-path \"hotfix/$name\")\" || return; git worktree add -b \"hotfix/$name\" \"$path\" \"$base\"; }; f"
    flow-release-start = "!f() { name=\"$1\"; test -n \"$name\" || { echo \"usage: git flow-release-start <name> [base]\"; return 2; }; base=\"${2:-$(git default-branch)}\"; path=\"$(git wt-path \"release/$name\")\" || return; git worktree add -b \"release/$name\" \"$path\" \"$base\"; }; f"
