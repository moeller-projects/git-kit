[alias]
    ma = merge --abort
    mc = merge --continue
    rebase-branch = "!f() { git rebase --interactive \"$(git merge-base \"$(git default-branch)\" HEAD)\"; }; f"
    ours = "!f() { git checkout --ours   \"$@\" && git add \"$@\"; }; f"
    theirs = "!f() { git checkout --theirs \"$@\" && git add \"$@\"; }; f"
    mgi = "!f() { command -v fzf >/dev/null 2>&1 || { echo \"mgi needs fzf\" >&2; return 2; }; b=\"$(git for-each-ref --format=\"%(refname:short)\" refs/heads/ refs/remotes/origin/ | grep -v \"^origin/HEAD$\" | fzf --preview \"git log --oneline --color=always -20 {}\" --prompt=\"merge> \")\"; [ -n \"$b\" ] || return 0; git merge \"$b\"; }; f"
