{
    "name": "@lukasmoeller/git-kit",
    "version": "3.0.0",
    "description": "A modular Git alias distribution toolkit.",
    "type": "module",
    "bin": {
        "git-kit": "dist/cli.js"
    },
    "files": [
        "dist",
        "aliases",
        "generated",
        "profiles",
        "docs",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "bun build src/cli.ts --outdir dist --target node",
        "test": "bun test",
        "generate": "bun src/cli.ts generate",
        "doctor": "bun src/cli.ts doctor",
        "validate": "bun src/cli.ts generate && git diff --exit-code generated docs"
    },
    "dependencies": {
        "commander": "15.0.0",
        "yaml": "2.9.0"
    },
    "devDependencies": {
        "@types/node": "25.9.1",
        "typescript": "6.0.3"
    },
    "license": "MIT"
}
